{
  "name": "edu-mesh",
  "version": "0.1.0",
  "description": "Plataforma educativa híbrida y de bajo costo: catálogo offline (SQLite) + distribución de archivos P2P en la red WiFi local + validación criptográfica de contenido curado y legal.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "keys": "node scripts/generate-keys.js",
    "setup": "node scripts/setup-demo.js",
    "seed": "node src/node-seed.js",
    "student": "node src/node-student.js",
    "app": "node src/node-app.js",
    "demo": "node src/node-app.js --home=nodes/semilla --name=Central",
    "maestro": "node scripts/launch.js",
    "add": "node scripts/add-content.js",
    "content": "node scripts/import-folder.js",
    "manifest": "node scripts/build-manifest.js",
    "import": "node scripts/import-manifest.js",
    "pack": "node scripts/build-pack.js",
    "sync": "node scripts/sync.js"
  },
  "keywords": [
    "p2p",
    "lan",
    "offline-first",
    "education",
    "sqlite",
    "ed25519",
    "content-addressed"
  ],
  "license": "MIT",
  "dependencies": {
    "node-sqlite3-wasm": "^0.8.58",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "selfsigned": "^5.5.0",
    "ws": "^8.21.0"
  }
}
