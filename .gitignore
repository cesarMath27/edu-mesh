# --- Dependencias ---
node_modules/

# --- Node.js portátil que descarga el instalador (pesado y por máquina) ---
runtime/

# --- PIN del maestro (estable entre clases; local, NUNCA se sube) ---
.teacher-pin

# --- Datos generados por cada nodo (cada "dispositivo" tiene su propio home) ---
nodes/

# --- Material del curador (libros/videos): pesado y local; se distribuye por
#     el mesh, NO por git. La estructura va documentada en el README. ---
contenido/

# --- Llaves y catálogo firmado: se generan localmente con `npm run setup`. ---
#     NUNCA subir llaves privadas. Se ignora toda la carpeta keys/ por seguridad.
keys/
manifest.json

# --- Proyecto distinto que vive en esta carpeta (Realidad Mixta / Meta Quest) ---
#     (anclado a la raíz: NO afecta a src/web/public/index.html)
/index.html

# --- Config local del editor / preview ---
.claude/

# --- Paquete de contenido publicable (se genera con npm run pack) ---
dist-pack/

# --- Artefactos varios ---
*.log
*.part
*.out.txt
*.xlsx
